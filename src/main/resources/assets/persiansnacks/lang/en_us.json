  "message.persiansnacks.titap.5": "\u0628\u0627\u0632\u0645 \u0645\u06cc\u062e\u0648\u0627\u06cc\u061f!",
  "message.persiansnacks.titap.6": "\u062a\u06cc\u062a\u0627\u067e = \u0627\u0646\u0631\u0698\u06cc!",
