  "message.persiansnacks.pofak.4": "\u067e\u0641\u06a9 \u0646\u0645\u06a9\u06cc = \u0632\u0646\u062f\u06af\u06cc!",
  "message.persiansnacks.pofak.5": "\u0628\u0627 \u067e\u0641\u06a9 \u0646\u0645\u06a9\u06cc \u067e\u0631\u0648\u0627\u0632 \u06a9\u0646!",
  "message.persiansnacks.pofak.6": "\u067e\u0641\u06a9 \u0646\u0645\u06a9\u06cc = \u0642\u062f\u0631\u062a!",
  "message.persiansnacks.pofak.7": "\u0634\u06a9\u0645 \u0633\u06cc\u0631 \u0646\u0645\u06cc\u0634\u0647 \u0628\u0627 \u067e\u0641\u06a9\u061f!",
  "message.persiansnacks.pofak.8": "\u067e\u0641\u06a9 \u0646\u0645\u06a9\u06cc = \u0639\u0634\u0642!",
  "message.persiansnacks.titap.1": "\u0645\u06af\u0647 \u0631\u0698\u06cc\u0645 \u0646\u062f\u0627\u0631\u06cc\u061f",
