  "message.persiansnacks.rangarang.1": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af \u0628\u0627\u0632 \u0634\u062f! \u0648\u0627\u06cc \u0686\u0647 \u0628\u0648\u06cc \u062e\u0648\u0628\u06cc!",
  "message.persiansnacks.rangarang.2": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af = \u062e\u0648\u0634\u0645\u0632\u0647\u200c\u062a\u0631\u06cc\u0646 \u0648\u0627\u0641\u0631\u06cc \u06a9\u0647 \u062e\u0648\u0631\u062f\u06cc!",
  "message.persiansnacks.rangarang.3": "\u0648\u0627\u06cc\u0633\u0627 \u0628\u0628\u06cc\u0646\u0645 \u0686\u06cc\u0647! \u0622\u0647\u0627\u0646 \u0631\u0646\u06af\u0627\u0631\u0646\u06af!",
  "message.persiansnacks.rangarang.4": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af \u0648\u0627\u0641\u0631\u06cc \u067e\u0631 \u0627\u0632 \u0639\u0634\u0642 \u0648 \u0627\u0646\u0631\u0698\u06cc!",
  "message.persiansnacks.rangarang.5": "\u0628\u0627 \u0631\u0646\u06af\u0627\u0631\u0646\u06af \u0631\u0646\u06af\u06cc\u0646 \u06a9\u0645\u0627\u0646 \u0631\u0648 \u0628\u0628\u06cc\u0646!",
  "message.persiansnacks.rangarang.6": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af = \u062e\u0646\u062f\u0647 + \u0627\u0646\u0631\u0698\u06cc!",
  "message.persiansnacks.rangarang.7": "\u0627\u06cc\u0646 \u0648\u0627\u0641\u0631\u0647 \u06cc\u0627 \u0628\u0647\u0634\u062a\u0647\u061f! \u0631\u0646\u06af\u0627\u0631\u0646\u06af!",
  "message.persiansnacks.rangarang.8": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af \u0631\u0648 \u0628\u0627\u0632 \u06a9\u0646 \u062a\u0627 \u062f\u0646\u06cc\u0627 \u0631\u0646\u06af\u06cc\u0646 \u0628\u0634\u0647!",
  "message.persiansnacks.rangarang.9": "\u06cc\u0647 \u0631\u0646\u06af\u0627\u0631\u0646\u06af \u0628\u062e\u0648\u0631 \u0642\u0634\u0646\u06af \u0628\u0634\u0648!",
  "message.persiansnacks.rangarang.10": "\u0631\u0646\u06af\u0627\u0631\u0646\u06af = \u0637\u0639\u0645 \u062e\u0648\u0646\u0647\u060c \u0637\u0639\u0645 \u0627\u06cc\u0631\u0627\u0646!",
  "message.persiansnacks.pofak.1": "\u067e\u0641\u06a9 \u0646\u0645\u06a9\u06cc = \u0627\u0646\u0631\u0698\u06cc!",
